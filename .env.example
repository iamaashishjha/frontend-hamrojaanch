# ─── HamroJaanch Frontend ───

# Backend API URL. Leave empty to use in-browser mock data.
VITE_API_BASE_URL=http://localhost:4000/api

# WebSocket signaling server for live proctoring.
VITE_SIGNALING_URL=ws://localhost:3001/ws

# HTTP endpoint for signaling server token requests.
VITE_SIGNALING_HTTP_URL=http://localhost:3001

# STUN/TURN servers for WebRTC (JSON array).
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
